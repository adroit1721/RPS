# MONGO_URI: Your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://...

# JWT_SECRET: A secret string for token signing
JWT_SECRET=supersecretchangeit

# PORT: Usually 5000 for local, Vercel handles it automatically
PORT=5000

# Optional: Frontend URL for CORS (e.g., https://your-app.vercel.app)
FRONTEND_URL=
